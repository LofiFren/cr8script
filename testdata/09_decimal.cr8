# cr8script numbers are decimal-by-default, so the classic float footgun
# `0.1 + 0.2 != 0.3` doesn't bite.
show 0.1 + 0.2
show 0.1 + 0.2 is 0.3

# Money math stays exact.
var running = 0.0
for each n in [0.10, 0.20, 0.30, 0.40]
  running = running + n
end
show running

# Whole numbers still print without a fractional tail.
show 1 + 1
show 10 / 4

# Long division keeps high precision (28 significant digits).
show 1 / 3

# Explicit rounding stays decimal.
show math.round(2.567)
show math.floor(3.9)
show math.ceil(3.1)
show math.sqrt(2)

# json round-trips numbers as decimal text.
let raw = "[0.1, 0.2, 0.3]"
let xs = json.parse(raw)
show sum(xs)
show json.stringify(xs)
