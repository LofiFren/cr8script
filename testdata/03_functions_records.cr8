to add(a, b)
  return a + b
end

to fact(n)
  if n is at most 1 then
    return 1
  end
  return n * fact(n - 1)
end

show add(2, 3)
show fact(6)

# Records are values, not objects
let p1 = { name: "Ada", age: 36 }
let p2 = p1.with({ age: 37 })

show p1.name
show p1.age
show p2.age
show p1.age      # original is untouched

# Closures
to make_adder(n)
  to inner(x)
    return x + n
  end
  return inner
end

let add5 = make_adder(5)
show add5(10)
show add5(20)
